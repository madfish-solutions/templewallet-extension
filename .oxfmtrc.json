{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSameLine": false,
  "singleQuote": true,
  "trailingComma": "none",
  "arrowParens": "avoid",
  "printWidth": 120,
  "sortImports": {
    "sortSideEffects": true,
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react"]
      }
    ],
    "groups": [
      "side_effect_style",
      "react",
      "side_effect",
      ["external", "builtin"],
      "internal",
      "parent",
      "sibling",
      "index",
      "unknown"
    ],
    "internalPattern": ["app/", "lib/", "temple/", "content-scripts/"],
    "order": "asc",
    "ignoreCase": true,
    "newlinesBetween": true
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "bin",
    "webpack",
    "*.config.ts",
    "*.embed.js",
    "**/*.html",
    "**/*.css",
    "**/*.json",
    "**/*.md",
    "**/*.yml",
    "**/*.yaml"
  ]
}
